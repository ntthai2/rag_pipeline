# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=rag_docs

# Embedding (Jina v3 via Infinity)
EMBEDDING_URL=http://jina-embedding:18081
EMBEDDING_MODEL=jinaai/jina-embeddings-v3
EMBEDDING_DIM=1024

# LLM (external vLLM from Week 1 - start it first!)
# From inside Docker network, use host.docker.internal to reach host machine
VLLM_URL=http://host.docker.internal/v1
VLLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct-AWQ
VLLM_API_KEY=secret-key-change-me

# RAG config
TOP_K=20
TOP_K_RERANK=5
SIMILARITY_THRESHOLD=0.3
CHUNK_SIZE=512
CHUNK_OVERLAP=50
